# Copy to .env and edit for your machine
PORT=5000
NODE_ENV=development

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=spacesync
DB_DIALECT=mysql

# CORS (frontend origin)
CORS_ORIGIN=http://localhost:5173

# JWT — change this to a long random string in production
JWT_SECRET=spacesync-dev-secret-change-me
JWT_EXPIRES_IN=7d
