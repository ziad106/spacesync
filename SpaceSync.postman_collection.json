{
  "info": {
    "name": "SpaceSync API",
    "_postman_id": "spacesync-collection-001",
    "description": "Full API test collection for SpaceSync (CSE 362 Lab Final). Covers health, resources, bookings, and negative cases.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "resourceId", "value": "1" },
    { "key": "bookingId", "value": "1" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /api/health",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/health", "host": ["{{baseUrl}}"], "path": ["api", "health"] }
          }
        }
      ]
    },
    {
      "name": "Resources",
      "item": [
        {
          "name": "GET /api/resources",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json();",
                  "pm.test('is array', () => pm.expect(Array.isArray(data)).to.be.true);",
                  "if (data.length) pm.collectionVariables.set('resourceId', data[0].id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/resources", "host": ["{{baseUrl}}"], "path": ["api", "resources"] }
          }
        },
        {
          "name": "POST /api/resources (valid)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "pm.test('has id', () => pm.expect(pm.response.json().id).to.be.a('number'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Temporary Room\",\n  \"type\": \"Room\",\n  \"capacity\": 20\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/resources", "host": ["{{baseUrl}}"], "path": ["api", "resources"] }
          }
        },
        {
          "name": "POST /api/resources (missing name - 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"type\": \"Room\",\n  \"capacity\": 20\n}" },
            "url": { "raw": "{{baseUrl}}/api/resources", "host": ["{{baseUrl}}"], "path": ["api", "resources"] }
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "POST /api/bookings (valid)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "const d = pm.response.json();",
                  "pm.test('has nested resource', () => pm.expect(d.resource).to.be.an('object'));",
                  "pm.collectionVariables.set('bookingId', d.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resource_id\": {{resourceId}},\n  \"requested_by\": \"Dr. Ali\",\n  \"booking_date\": \"2026-05-10\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/bookings", "host": ["{{baseUrl}}"], "path": ["api", "bookings"] }
          }
        },
        {
          "name": "POST /api/bookings (double-booking - 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 400', () => pm.response.to.have.status(400));",
                  "pm.test('has error msg', () => pm.expect(pm.response.json().error).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resource_id\": {{resourceId}},\n  \"requested_by\": \"Prof. Rahim\",\n  \"booking_date\": \"2026-05-10\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/bookings", "host": ["{{baseUrl}}"], "path": ["api", "bookings"] }
          }
        },
        {
          "name": "POST /api/bookings (invalid date - 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resource_id\": {{resourceId}},\n  \"requested_by\": \"Dr. Ali\",\n  \"booking_date\": \"not-a-date\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/bookings", "host": ["{{baseUrl}}"], "path": ["api", "bookings"] }
          }
        },
        {
          "name": "GET /api/bookings",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json();",
                  "pm.test('is array', () => pm.expect(Array.isArray(data)).to.be.true);",
                  "if (data.length) pm.test('includes resource', () => pm.expect(data[0].resource).to.be.an('object'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/bookings", "host": ["{{baseUrl}}"], "path": ["api", "bookings"] }
          }
        },
        {
          "name": "DELETE /api/bookings/:id",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('deleted true', () => pm.expect(pm.response.json().deleted).to.eql(true));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/bookings/{{bookingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bookings", "{{bookingId}}"]
            }
          }
        },
        {
          "name": "DELETE /api/bookings/:id (not found - 404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/bookings/999999",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bookings", "999999"]
            }
          }
        }
      ]
    }
  ]
}
